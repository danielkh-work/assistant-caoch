{
    "openapi": "3.0.0",
    "info": {
        "title": "Human Dashboard API",
        "version": "1.0.0"
    },
    "paths": {
        "/api/configurations": {
            "get": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Get all configurations",
                "description": "Returns every configuration entry as key and value.",
                "operationId": "listConfigurations",
                "responses": {
                    "200": {
                        "description": "List of configurations",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "key": {
                                                "type": "string",
                                                "example": "RPP_CONFIGURATION"
                                            },
                                            "value": {
                                                "type": "string",
                                                "example": "with_rpp"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Update configurations",
                "description": "Bulk upsert configuration entries by key.",
                "operationId": "updateConfigurations",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "configurations"
                                ],
                                "properties": {
                                    "configurations": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "key",
                                                "value"
                                            ],
                                            "properties": {
                                                "key": {
                                                    "type": "string",
                                                    "example": "RPP_CONFIGURATION"
                                                },
                                                "value": {
                                                    "oneOf": [
                                                        {
                                                            "type": "string",
                                                            "maxLength": 255,
                                                            "pattern": "^[A-Za-z0-9_]+$",
                                                            "example": "with_rpp"
                                                        },
                                                        {
                                                            "type": "boolean",
                                                            "example": true
                                                        },
                                                        {
                                                            "type": "integer",
                                                            "example": 11
                                                        }
                                                    ]
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "minItems": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated configurations",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "key": {
                                                "type": "string"
                                            },
                                            "value": {
                                                "type": "string"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Create a configuration",
                "description": "Add a new configuration key. Key and value must contain only letters, numbers, and underscores. Value max length is 255.",
                "operationId": "createConfiguration",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "key",
                                    "value"
                                ],
                                "properties": {
                                    "key": {
                                        "type": "string",
                                        "pattern": "^[A-Za-z0-9_]+$",
                                        "example": "RPP_CONFIGURATION"
                                    },
                                    "value": {
                                        "oneOf": [
                                            {
                                                "type": "string",
                                                "maxLength": 255,
                                                "pattern": "^[A-Za-z0-9_]+$",
                                                "example": "with_rpp"
                                            },
                                            {
                                                "type": "boolean",
                                                "example": true
                                            },
                                            {
                                                "type": "integer",
                                                "example": 11
                                            }
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created configuration",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "key": {
                                            "type": "string",
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "RPP_CONFIGURATION"
                                        },
                                        "value": {
                                            "type": "string",
                                            "maxLength": 255,
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "with_rpp"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error (including duplicate key)"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/configurations/{key}": {
            "get": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Get a single configuration by key",
                "description": "Returns one configuration entry for the given key.",
                "operationId": "getConfigurationByKey",
                "parameters": [
                    {
                        "name": "key",
                        "in": "path",
                        "description": "Configuration key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "RPP_CONFIGURATION"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Configuration entry",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "key": {
                                            "type": "string",
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "RPP_CONFIGURATION"
                                        },
                                        "value": {
                                            "type": "string",
                                            "maxLength": 255,
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "with_rpp"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Configuration not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/logout-qb-applicaion/{id}": {
            "get": {
                "tags": [
                    "QB Logout"
                ],
                "summary": "QB application logout",
                "description": "Clears `session_id` and `is_loggin` for the QB user. Postman: **QB Logout Success**.",
                "operationId": "logoutQbApplication",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "QB user primary key",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 78
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logout succeeded, or user was not found (see `status` and `message` in the JSON body; HTTP code may still be 200).",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "properties": {
                                                "status": {
                                                    "type": "integer",
                                                    "example": 200
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "logout successful"
                                                },
                                                "user": {
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "session_id": {
                                                            "type": "string",
                                                            "nullable": true
                                                        },
                                                        "code": {
                                                            "type": "string",
                                                            "nullable": true
                                                        },
                                                        "head_coach_id": {
                                                            "type": "integer",
                                                            "nullable": true
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        {
                                            "properties": {
                                                "status": {
                                                    "type": "integer",
                                                    "example": 404
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "User not found"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/qb-session-login-status/{session_id}": {
            "get": {
                "tags": [
                    "QB Logout"
                ],
                "summary": "Check QB login status",
                "description": "Returns **200** when a QB user is bound to the given mobile session UUID. Returns **401** when no QB has this `session_id` (Postman **Check QB Login Status 200** / invalid session **Check QB Login Status 403** — API uses **401 Unauthenticated**).",
                "operationId": "qbSessionLoginStatus",
                "parameters": [
                    {
                        "name": "session_id",
                        "in": "path",
                        "description": "Mobile pairing session UUID from `POST /api/mobile/create-session`",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid",
                            "example": "822fc835-75aa-48bf-8473-354a4913aab2"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "QB is linked to this session",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 200
                                        },
                                        "session_id": {
                                            "type": "string",
                                            "format": "uuid"
                                        },
                                        "logged_in": {
                                            "description": "Mirrors the QB user's `is_loggin` flag in the database.",
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated — no QB user with this session_id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 401
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Sanctum bearer token. Use format: Bearer {token}",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Configuration",
            "description": "Application configuration key-value store"
        },
        {
            "name": "QB Logout",
            "description": "QB application logout and session login status"
        }
    ]
}