{
    "openapi": "3.0.0",
    "info": {
        "title": "Human Dashboard API",
        "version": "1.0.0"
    },
    "paths": {
        "/api/configurations": {
            "get": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Get all configurations",
                "description": "Returns every configuration entry as key and value.",
                "operationId": "listConfigurations",
                "responses": {
                    "200": {
                        "description": "List of configurations",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "key": {
                                                "type": "string",
                                                "example": "RPP_CONFIGURATION"
                                            },
                                            "value": {
                                                "type": "string",
                                                "example": "with_rpp"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Update configurations",
                "description": "Bulk upsert configuration entries by key.",
                "operationId": "updateConfigurations",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "configurations"
                                ],
                                "properties": {
                                    "configurations": {
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "key",
                                                "value"
                                            ],
                                            "properties": {
                                                "key": {
                                                    "type": "string",
                                                    "example": "RPP_CONFIGURATION"
                                                },
                                                "value": {
                                                    "oneOf": [
                                                        {
                                                            "type": "string",
                                                            "maxLength": 255,
                                                            "pattern": "^[A-Za-z0-9_]+$",
                                                            "example": "with_rpp"
                                                        },
                                                        {
                                                            "type": "boolean",
                                                            "example": true
                                                        },
                                                        {
                                                            "type": "integer",
                                                            "example": 11
                                                        }
                                                    ]
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "minItems": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Updated configurations",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "key": {
                                                "type": "string"
                                            },
                                            "value": {
                                                "type": "string"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Create a configuration",
                "description": "Add a new configuration key. Key and value must contain only letters, numbers, and underscores. Value max length is 255.",
                "operationId": "createConfiguration",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "key",
                                    "value"
                                ],
                                "properties": {
                                    "key": {
                                        "type": "string",
                                        "pattern": "^[A-Za-z0-9_]+$",
                                        "example": "RPP_CONFIGURATION"
                                    },
                                    "value": {
                                        "oneOf": [
                                            {
                                                "type": "string",
                                                "maxLength": 255,
                                                "pattern": "^[A-Za-z0-9_]+$",
                                                "example": "with_rpp"
                                            },
                                            {
                                                "type": "boolean",
                                                "example": true
                                            },
                                            {
                                                "type": "integer",
                                                "example": 11
                                            }
                                        ]
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Created configuration",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "key": {
                                            "type": "string",
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "RPP_CONFIGURATION"
                                        },
                                        "value": {
                                            "type": "string",
                                            "maxLength": 255,
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "with_rpp"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error (including duplicate key)"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/configurations/{key}": {
            "get": {
                "tags": [
                    "Configuration"
                ],
                "summary": "Get a single configuration by key",
                "description": "Returns one configuration entry for the given key.",
                "operationId": "getConfigurationByKey",
                "parameters": [
                    {
                        "name": "key",
                        "in": "path",
                        "description": "Configuration key",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "RPP_CONFIGURATION"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Configuration entry",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "key": {
                                            "type": "string",
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "RPP_CONFIGURATION"
                                        },
                                        "value": {
                                            "type": "string",
                                            "maxLength": 255,
                                            "pattern": "^[A-Za-z0-9_]+$",
                                            "example": "with_rpp"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "404": {
                        "description": "Configuration not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/logout-qb-applicaion/{id}": {
            "get": {
                "tags": [
                    "QB Logout"
                ],
                "summary": "QB application logout",
                "description": "Clears `session_id` and `is_loggin` for the QB user. Postman: **QB Logout Success**.",
                "operationId": "logoutQbApplication",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "QB user primary key",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 78
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logout succeeded, or user was not found (see `status` and `message` in the JSON body; HTTP code may still be 200).",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "properties": {
                                                "status": {
                                                    "type": "integer",
                                                    "example": 200
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "logout successful"
                                                },
                                                "user": {
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "session_id": {
                                                            "type": "string",
                                                            "nullable": true
                                                        },
                                                        "code": {
                                                            "type": "string",
                                                            "nullable": true
                                                        },
                                                        "head_coach_id": {
                                                            "type": "integer",
                                                            "nullable": true
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        {
                                            "properties": {
                                                "status": {
                                                    "type": "integer",
                                                    "example": 404
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "User not found"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/qb-session-login-status/{session_id}": {
            "get": {
                "tags": [
                    "QB Logout"
                ],
                "summary": "Check QB login status",
                "description": "Returns **200** when a QB user is bound to the given mobile session UUID. Returns **401** when no QB has this `session_id` (Postman **Check QB Login Status 200** / invalid session **Check QB Login Status 403** — API uses **401 Unauthenticated**).",
                "operationId": "qbSessionLoginStatus",
                "parameters": [
                    {
                        "name": "session_id",
                        "in": "path",
                        "description": "Mobile pairing session UUID from `POST /api/mobile/create-session`",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid",
                            "example": "822fc835-75aa-48bf-8473-354a4913aab2"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "QB is linked to this session",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 200
                                        },
                                        "session_id": {
                                            "type": "string",
                                            "format": "uuid"
                                        },
                                        "logged_in": {
                                            "description": "Mirrors the QB user's `is_loggin` flag in the database.",
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated — no QB user with this session_id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 401
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/upload-play-list": {
            "get": {
                "tags": [
                    "Plays"
                ],
                "summary": "List offensive plays",
                "description": "Returns plays for a league including `hmark_left`, `hmark_center`, and `hmark_right`. Pass `page`, `per_page`, or `search` to enable pagination.",
                "operationId": "listPlays",
                "parameters": [
                    {
                        "name": "league_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 22
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 4
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "Brazil"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Play list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PlayListBaseResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/uplaod-play": {
            "post": {
                "tags": [
                    "Plays"
                ],
                "summary": "Create offensive play",
                "description": "Upload a new offensive play. Requires all three H-mark images (`hmark_left`, `hmark_center`, `hmark_right`). Note: route path uses legacy spelling `uplaod-play`.",
                "operationId": "createPlay",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/PlayMultipartFields"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Play created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PlayBaseResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/update-play/{id}": {
            "post": {
                "tags": [
                    "Plays"
                ],
                "summary": "Update offensive play",
                "description": "Update an existing play. H-mark images are optional when existing paths are already stored; send new files to replace. `playType` is optional on update.",
                "operationId": "updatePlay",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 191
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/PlayMultipartFields"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Play updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PlayBaseResponse"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "Play": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 191
                    },
                    "league_id": {
                        "type": "integer",
                        "example": 22
                    },
                    "play_name": {
                        "type": "string",
                        "example": "Brazil"
                    },
                    "play_type": {
                        "type": "integer",
                        "example": 1
                    },
                    "offensive_play_type": {
                        "type": "string",
                        "enum": [
                            "run",
                            "pass",
                            "rpo",
                            "play_action"
                        ],
                        "example": "pass"
                    },
                    "zone_selection": {
                        "type": "integer",
                        "example": 2
                    },
                    "min_expected_yard": {
                        "type": "string",
                        "example": "short"
                    },
                    "max_expected_yard": {
                        "type": "string",
                        "example": "1"
                    },
                    "possession": {
                        "type": "string",
                        "enum": [
                            "offensive",
                            "defensive"
                        ],
                        "example": "offensive"
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "hmark_left": {
                        "type": "string",
                        "example": "uploads/public/abc.png",
                        "nullable": true
                    },
                    "hmark_center": {
                        "type": "string",
                        "example": "uploads/public/def.png",
                        "nullable": true
                    },
                    "hmark_right": {
                        "type": "string",
                        "example": "uploads/public/ghi.png",
                        "nullable": true
                    },
                    "preferred_down": {
                        "type": "string",
                        "example": "1,2,3",
                        "nullable": true
                    },
                    "strategies": {
                        "type": "string",
                        "example": "regular,hurry up",
                        "nullable": true
                    },
                    "read_1": {
                        "type": "string",
                        "nullable": true
                    },
                    "read_2": {
                        "type": "string",
                        "nullable": true
                    },
                    "win_result": {
                        "description": "Present on list responses",
                        "type": "integer",
                        "example": 3
                    },
                    "loss_result": {
                        "type": "integer",
                        "example": 1
                    },
                    "yardage_difference": {
                        "type": "number",
                        "format": "float",
                        "example": 12.5,
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "PlayBaseResponse": {
                "properties": {
                    "status": {
                        "type": "integer",
                        "example": 200
                    },
                    "message": {
                        "type": "string",
                        "example": "Play Uploaded Successfully"
                    },
                    "data": {
                        "$ref": "#/components/schemas/Play"
                    }
                },
                "type": "object"
            },
            "PlayListBaseResponse": {
                "properties": {
                    "status": {
                        "type": "integer",
                        "example": 200
                    },
                    "message": {
                        "type": "string",
                        "example": "Play Uploaded List "
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Play"
                        }
                    },
                    "pagination": {
                        "properties": {
                            "total": {
                                "type": "integer",
                                "example": 12
                            },
                            "current_page": {
                                "type": "integer",
                                "example": 1
                            },
                            "per_page": {
                                "type": "integer",
                                "example": 4
                            },
                            "last_page": {
                                "type": "integer",
                                "example": 3
                            }
                        },
                        "type": "object",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "PlayMultipartFields": {
                "required": [
                    "play_name",
                    "playType",
                    "league_id",
                    "play_type",
                    "zone_selection",
                    "min_expected_yard",
                    "max_expected_yard",
                    "target_offensive",
                    "opposing_defensive",
                    "pre_snap_motion",
                    "play_action_fake",
                    "possession"
                ],
                "properties": {
                    "play_name": {
                        "type": "string",
                        "example": "Brazil"
                    },
                    "playType": {
                        "type": "string",
                        "enum": [
                            "run",
                            "pass",
                            "rpo",
                            "play_action"
                        ],
                        "example": "pass"
                    },
                    "league_id": {
                        "type": "integer",
                        "example": 22
                    },
                    "play_type": {
                        "type": "integer",
                        "example": 1
                    },
                    "zone_selection": {
                        "type": "integer",
                        "example": 2
                    },
                    "min_expected_yard": {
                        "type": "string",
                        "example": "short"
                    },
                    "max_expected_yard": {
                        "type": "string",
                        "example": "1"
                    },
                    "target_offensive": {
                        "type": "integer",
                        "example": 1
                    },
                    "opposing_defensive": {
                        "type": "integer",
                        "example": 3
                    },
                    "pre_snap_motion": {
                        "type": "integer",
                        "example": 0
                    },
                    "play_action_fake": {
                        "type": "integer",
                        "example": 0
                    },
                    "possession": {
                        "type": "string",
                        "enum": [
                            "offensive",
                            "defensive"
                        ],
                        "example": "offensive"
                    },
                    "quarter": {
                        "type": "integer",
                        "example": 1
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "preferred_down": {
                        "type": "string",
                        "example": "1,2,3"
                    },
                    "strategies": {
                        "type": "string",
                        "example": "regular,hurry up"
                    },
                    "read_2": {
                        "description": "Stored as read_1",
                        "type": "string",
                        "nullable": true
                    },
                    "read_3": {
                        "description": "Stored as read_2",
                        "type": "string",
                        "nullable": true
                    },
                    "position_status": {
                        "type": "integer",
                        "example": 1
                    },
                    "groups[]": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        }
                    },
                    "offensive[40]": {
                        "description": "Offensive position strength keyed by position id",
                        "type": "integer",
                        "example": 0
                    },
                    "defensive[70]": {
                        "description": "Defensive position strength keyed by position id",
                        "type": "integer",
                        "example": 0
                    },
                    "hmark_left": {
                        "description": "Required on create",
                        "type": "string",
                        "format": "binary"
                    },
                    "hmark_center": {
                        "description": "Required on create",
                        "type": "string",
                        "format": "binary"
                    },
                    "hmark_right": {
                        "description": "Required on create",
                        "type": "string",
                        "format": "binary"
                    },
                    "video": {
                        "type": "string",
                        "format": "binary",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Sanctum bearer token. Use format: Bearer {token}",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Configuration",
            "description": "Application configuration key-value store"
        },
        {
            "name": "QB Logout",
            "description": "QB application logout and session login status"
        },
        {
            "name": "Plays",
            "description": "Offensive play create, update, and listing (H-mark images)"
        }
    ]
}