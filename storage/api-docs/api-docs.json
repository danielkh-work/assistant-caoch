{
    "openapi": "3.0.0",
    "info": {
        "title": "Human Dashboard API",
        "description": "QB session login status and QB application logout. Postman `{{base_url}}` should match `L5_SWAGGER_CONST_HOST` + `/api` paths below (e.g. `http://localhost:8000/api` → set host to `http://localhost:8000`).",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Application base URL (no trailing slash). Override with `L5_SWAGGER_CONST_HOST` in `.env`."
        }
    ],
    "paths": {
        "/api/logout-qb-applicaion/{id}": {
            "get": {
                "tags": [
                    "Human Dashboard"
                ],
                "summary": "QB application logout",
                "description": "Clears `session_id` and `is_loggin` for the QB user. Postman: **QB Logout Success**.",
                "operationId": "logoutQbApplication",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "QB user primary key",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 78
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logout succeeded, or user was not found (see `status` and `message` in the JSON body; HTTP code may still be 200).",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "properties": {
                                                "status": {
                                                    "type": "integer",
                                                    "example": 200
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "logout successful"
                                                },
                                                "user": {
                                                    "properties": {
                                                        "name": {
                                                            "type": "string"
                                                        },
                                                        "session_id": {
                                                            "type": "string",
                                                            "nullable": true
                                                        },
                                                        "code": {
                                                            "type": "string",
                                                            "nullable": true
                                                        },
                                                        "head_coach_id": {
                                                            "type": "integer",
                                                            "nullable": true
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        {
                                            "properties": {
                                                "status": {
                                                    "type": "integer",
                                                    "example": 404
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "User not found"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/qb-session-login-status/{session_id}": {
            "get": {
                "tags": [
                    "Human Dashboard"
                ],
                "summary": "Check QB login status",
                "description": "Returns **200** when a QB user is bound to the given mobile session UUID. Returns **401** when no QB has this `session_id` (Postman **Check QB Login Status 200** / invalid session **Check QB Login Status 403** — API uses **401 Unauthenticated**).",
                "operationId": "qbSessionLoginStatus",
                "parameters": [
                    {
                        "name": "session_id",
                        "in": "path",
                        "description": "Mobile pairing session UUID from `POST /api/mobile/create-session`",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid",
                            "example": "822fc835-75aa-48bf-8473-354a4913aab2"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "QB is linked to this session",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 200
                                        },
                                        "session_id": {
                                            "type": "string",
                                            "format": "uuid"
                                        },
                                        "logged_in": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated — no QB user with this session_id",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 401
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "Human Dashboard",
            "description": "QB session flows (Human Dashboard Postman collection)"
        }
    ]
}